{
  "name": "task-pad",
  "version": "1.3.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:dev": "ng serve --configuration=development",
    "start:prod": "ng serve --configuration=production",
    "build": "ng build",
    "build:dev": "ng build --configuration=development",
    "build:prod": "ng build --configuration=production",
    "watch": "ng build --watch --configuration development",
    "server": "nodemon server.js",
    "server:dev": "NODE_ENV=development nodemon server.js",
    "server:local": "NODE_ENV=development nodemon --env-file=.env.local server.js",
    "server:prod": "NODE_ENV=production node server.js",
    "dev:api": "nodemon server.js",
    "dev": "concurrently \"npm run server:dev\" \"npm run start:dev\"",
    "dev:local": "concurrently \"npm run server:local\" \"npm run start:dev\"",
    "build:full": "npm run build:prod && npm run server:prod",
    "test": "ng test",
    "test:api": "NODE_ENV=test node --test tests/"
  },
  "private": true,
  "packageManager": "npm@11.12.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/fire": "^21.0.0-rc.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@prisma/adapter-pg": "^7.5.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "dotenv-flow": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "firebase": "^11.0.0",
    "firebase-admin": "^13.7.0",
    "flatpickr": "^4.6.13",
    "helmet": "^8.1.0",
    "k6": "^0.0.0",
    "postgres": "^3.4.8",
    "prom-client": "^15.1.3",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.26.24",
    "tslib": "^2.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^28.0.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  },
  "description": "This project was generated using [Angular CLI](https://github.com/angular/angular-cli) version 21.2.3.",
  "main": "drizzle.config.js",

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Task {
  id             String   @id @default(uuid())
  title          String
  description    String
  estimatedHours Float
  tags           String[] @default([])
  status         String   @default("To Do")
  userId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
